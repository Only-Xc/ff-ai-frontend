{
  "name": "@ff-ai-frontend/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./number": {
      "types": "./src/number/index.ts",
      "import": "./src/number/index.ts"
    },
    "./request": {
      "types": "./src/request/index.ts",
      "import": "./src/request/index.ts"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "import": "./src/storage/index.ts"
    },
    "./crypto": {
      "types": "./src/crypto/index.ts",
      "import": "./src/crypto/index.ts"
    },
    "./websocket": {
      "types": "./src/websocket/index.ts",
      "import": "./src/websocket/index.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "oxlint && eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "oxfmt . --ignore-path ../../.gitignore --write",
    "format:check": "oxfmt . --ignore-path ../../.gitignore --check"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bignumber.js": "^9.3.1",
    "crypto-js": "^4.2.0",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@ff-ai-frontend/tooling": "workspace:*",
    "@types/crypto-js": "^4.2.2",
    "eslint": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
