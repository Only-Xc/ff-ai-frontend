{
  "name": "@ff-ai-frontend/dictionaries",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "oxlint && eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "oxfmt . --ignore-path ../../.gitignore --write",
    "format:check": "oxfmt . --ignore-path ../../.gitignore --check"
  },
  "dependencies": {
    "antd": "^6.3.7",
    "lodash-es": "^4.18.1",
    "react": "catalog:",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@ff-ai-frontend/tooling": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "catalog:",
    "eslint": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
