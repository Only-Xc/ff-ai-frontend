{
  "name": "@ff-ai-frontend/components",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts"
    },
    "./tailwind-source.css": "./src/tailwind-source.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "index.ts",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "oxlint && eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "oxfmt . --ignore-path ../../.gitignore --write",
    "format:check": "oxfmt . --ignore-path ../../.gitignore --check"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@ff-ai-frontend/dictionaries": "workspace:*",
    "antd": "^6.3.7",
    "antd-style": "^4.1.0",
    "dayjs": "^1.11.20",
    "lodash-es": "^4.18.1",
    "react": "catalog:",
    "react-router": "^7.14.2",
    "usehooks-ts": "^3.1.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@ff-ai-frontend/tooling": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "catalog:",
    "eslint": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
